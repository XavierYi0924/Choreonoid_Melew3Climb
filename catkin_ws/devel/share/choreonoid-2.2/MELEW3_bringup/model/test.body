format: ChoreonoidBody
formatVersion: 1.0
angleUnit: degree
name: TestEnvironment

links:
  - name: Floor
    jointType: fixed
    elements:
      - type: Shape
        geometry:
          type: Box
          size: [ 2, 2, 0.1 ]
        appearance:
          material:
            diffuseColor: [ 0.5, 0.5, 0.5 ]
        material:
          staticFriction: 1.0
          restitution: 0.9 # 高弹性

  - name: Ball
    parent: Floor
    jointType: free
    translation: [ 0, 0, 1.0 ] # 初始高度1米
    elements:
      - type: RigidBody
        mass: 0.5
        inertia: [ 0.002, 0, 0, 0, 0.002, 0, 0, 0, 0.002]
        geometry:
      -type: Shape
        geometry:  
          type: Sphere
          radius: 0.1
        appearance:
          material:
            diffuseColor: [ 0.8, 0.2, 0.2 ]
    material:
      staticFriction: 0.8
      restitution: 0.9