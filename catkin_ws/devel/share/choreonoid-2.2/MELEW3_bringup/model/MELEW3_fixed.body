    #  車輪--------------------------------------------------
  -
    name: WHEEL_FR
    parent: KNEE_FR
    translation: [ 0, 0, -0.2 ]
    jointType: revolute
    jointAxis: Y
    
    maxJointVelocity: 90
    jointId: 17
    elements: *WHEEL

    # 車輪回転マーク --------------------------------------------------
  -
