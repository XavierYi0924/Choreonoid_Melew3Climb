    parent: WHEEL_FR
    translation: [ 0, -0.006, -0.05 ]
    jointType: fixed
    elements: *ROTATION_MARK

#BackLeft

  # Yaw--------------------------------------------------
  -
    name: HIP_YAW_BL
    parent: BODY
    translation: [ -0.25, 0.2, 0 ]
    jointType: revolute
    jointAxis: Z
    jointRange: [ -90, 90 ]
    maxJointVelocity: 90
    jointId: 8
    elements: *HIP_YAW

    # Roll --------------------------------------------------
  -
