<launch>
  <group ns="MELEW3">
    <!-- Load yaml -->
      <rosparam file="$(find melew3_control)/config/MELEW3_real.yaml" command="load"/>
      <rosparam file="$(find melew3_control)/config/MELEW3_control.yaml" command="load"/>

    <!-- Load the controller -->
      <node name="MELEW3_control" pkg="melew3_control" type="MELEW3_control" output="screen" respawn="false"/>
  </group>

  <!-- dynamic_reconfigure -->
  <node name="rqt_reconfigure" pkg="rqt_reconfigure" type="rqt_reconfigure"/>
</launch>